{
  "name": "@open-inspect/docker-sandbox-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file-if-exists=.env.local --import tsx src/index.ts",
