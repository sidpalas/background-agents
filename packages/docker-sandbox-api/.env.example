# Copy to .env.local for local Docker sandbox API runs.

PORT=8788
DOCKER_SANDBOX_API_TOKEN=local-docker-sandbox-token
DOCKER_SANDBOX_IMAGE=open-inspect-sandbox-runtime:local
DOCKER_SANDBOX_PASSTHROUGH_ENV_VARS=ANTHROPIC_API_KEY,OPENAI_API_KEY,OPENCODE_API_KEY

# Optional model API keys copied into sandbox containers when listed above.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENCODE_API_KEY=
