# Open-Inspect Railway deployment placeholders.
# Copy to a local, untracked file before filling secrets, for example:
#   cp .env.example .env.railway
#
# These values are intended to be mapped into Railway service variables.
# Do not commit filled secret values.

# =============================================================================
# Public URLs
# =============================================================================

# Web app public URL. Update after the Railway web service has a domain.
WEB_APP_URL=https://YOUR-WEB-SERVICE.up.railway.app
NEXTAUTH_URL=https://YOUR-WEB-SERVICE.up.railway.app

# Control plane public URL. Update after the Railway control-plane service has a domain.
CONTROL_PLANE_URL=https://YOUR-CONTROL-PLANE-SERVICE.up.railway.app
WORKER_URL=https://YOUR-CONTROL-PLANE-SERVICE.up.railway.app
NEXT_PUBLIC_WS_URL=wss://YOUR-CONTROL-PLANE-SERVICE.up.railway.app

# For the web service's server-side CONTROL_PLANE_URL, prefer Railway private networking:
# CONTROL_PLANE_URL=http://${{control-plane.RAILWAY_PRIVATE_DOMAIN}}:${{control-plane.PORT}}

# =============================================================================
# Runtime / Deployment
# =============================================================================

DEPLOYMENT_NAME=open-inspect
SANDBOX_PROVIDER=modal
SCM_PROVIDER=github
LOG_LEVEL=info
NODE_ENV=production
NEXT_PUBLIC_SANDBOX_PROVIDER=modal

# =============================================================================
# Railway Managed Services
# =============================================================================

# Railway Postgres should provide DATABASE_URL automatically once attached.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Railway Redis should provide REDIS_URL automatically once attached.
REDIS_URL=${{Redis.REDIS_URL}}

# Railway object storage bucket / S3-compatible credentials.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# =============================================================================
# GitHub OAuth / GitHub App
# =============================================================================

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=

# =============================================================================
# Auth / Encryption Secrets
# =============================================================================

# Generate base64 values with: openssl rand -base64 32
NEXTAUTH_SECRET=
TOKEN_ENCRYPTION_KEY=
REPO_SECRETS_ENCRYPTION_KEY=
INTERNAL_CALLBACK_SECRET=

# Generate with: openssl rand -hex 32
MODAL_API_SECRET=

# =============================================================================
# Modal Sandbox Backend
# =============================================================================

MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_WORKSPACE=

# Modal secrets used by packages/modal-infra deployment.
ANTHROPIC_API_KEY=
ALLOWED_CONTROL_PLANE_HOSTS=YOUR-CONTROL-PLANE-SERVICE.up.railway.app

# =============================================================================
# Access Control
# =============================================================================

# Comma-separated GitHub usernames and/or email domains.
ALLOWED_USERS=
ALLOWED_EMAIL_DOMAINS=
UNSAFE_ALLOW_ALL_USERS=false

# =============================================================================
# Optional Integrations
# =============================================================================

ENABLE_SLACK_BOT=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

ENABLE_GITHUB_BOT=false
GITHUB_WEBHOOK_SECRET=

ENABLE_LINEAR_BOT=false
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
